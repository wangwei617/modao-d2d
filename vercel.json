{
  "buildCommand": "cd modao-d2d-app && npm install && npm run build",
  "installCommand": "npm install",
  "outputDirectory": ".",
  "framework": null,
  "rewrites": [
    {
      "source": "/app",
      "destination": "/modao-d2d-app/dist/index.html"
    },
    {
      "source": "/app/",
      "destination": "/modao-d2d-app/dist/index.html"
    },
    {
      "source": "/app/:path*",
      "destination": "/modao-d2d-app/dist/:path*"
    },
    {
      "source": "/prd",
      "destination": "/prd/index.html"
    },
    {
      "source": "/prd/",
      "destination": "/prd/index.html"
    }
  ]
}
